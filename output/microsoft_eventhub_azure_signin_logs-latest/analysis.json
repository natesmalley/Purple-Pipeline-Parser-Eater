    "raw_response": "{\n  \"semantic_summary\": \"This parser processes Microsoft Azure Event Hub sign-in logs, transforming raw authentication and access events into normalized OCSF format. It captures detailed authentication metadata including user identity, device context, location information, risk assessments, and conditional access status for Azure AD sign-in events.\",\n  \"parser_complexity\": {\n    \"level\": \"High\",\n    \"factors\": [\n      \"Multiple nested JSON parsing stages\",\n      \"Complex field transformations\",\n      \"Extensive attribute blacklisting\",\n      \"Geographical coordinate handling\",\n      \"Multiple format blocks with interdependencies\",\n      \"Rich authentication metadata processing\"\n    ],\n    \"confidence\": 0.92\n  },\n  \"field_mappings\": {\n    \"userPrincipalName\": {\n      \"target_ocsf_field\": \"user.email_addr\",\n      \"transformation_type\": \"copy\",\n      \"confidence\": 0.95\n    },\n    \"callerIpAddress\": {\n      \"target_ocsf_field\": \"src.ip.address\",\n      \"transformation_type\": \"copy\",\n      \"confidence\": 0.95\n    },\n    \"deviceDetail\": {\n      \"target_ocsf_field\": \"device\",\n      \"transformation_type\": \"json_parse\",\n      \"confidence\": 0.90\n    }\n  },\n  \"ocsf_classification\": {\n    \"class_uid\": 3002,\n    \"class_name\": \"Authentication\",\n    \"category_uid\": 3,\n    \"category_name\": \"Identity & Access Management\",\n    \"confidence\": 0.98\n  },\n  \"data_source_analysis\": {\n    \"vendor\": \"Microsoft\",\n    \"product\": \"Azure Event Hub\",\n    \"log_format\": \"JSON\",\n    \"ingestion_method\": \"Event Hub\"\n  },\n  \"optimization_opportunities\": [\n    \"Consolidate multiple JSON parsing stages\",\n    \"Implement batch processing for high-volume scenarios\",\n    \"Cache frequently accessed field mappings\",\n    \"Add validation for required fields\",\n    \"Implement error recovery for malformed records\",\n    \"Consider streaming processing optimization\"\n  ],\n  \"performance_characteristics\": {\n    \"expected_volume\": \"High\",\n    \"processing_complexity\": \"Complex\",\n    \"resource_requirements\": \"High\"\n  },\n  \"overall_confidence\": 0.92\n}",
    "selected_template": "ocsf_schema_mapping",
    "lua_code": "-- SentinelOne Parser: microsoft_eventhub_azure_signin_logs-latest \n-- OCSF Class: Authentication (3002)\n-- Performance Level: High-volume optimized\n-- Generated: 2025-10-13T11:09:26.712851\n\n-- Pre-compile frequently used patterns\nlocal PATTERNS = {\n    email = \"^[%w%.%-]+@[%w%.%-]+%.%w+$\",\n    ip = \"^%d+%.%d+%.%d+%.%d+$\"\n}\n\n-- Cached field mappings for performance\nlocal FIELD_MAPPINGS = {\n    -- Core fields\n    time = \"access_activity.time\",\n    resourceId = \"resource.account_uid\", \n    operationName = \"api.operation\",\n    category = \"event.type\",\n    tenantId = \"tenant.uid\",\n    \n    -- User fields\n    userPrincipalName = \"user.email_addr\",\n    userDisplayName = \"user.name\",\n    userId = \"user.uid\",\n    userType = \"user.type\",\n    \n    -- Device fields \n    deviceId = \"device.uid\",\n    operatingSystem = \"device.os\",\n    browser = \"device.browser\",\n    \n    -- Network fields\n    callerIpAddress = \"src.ip.address\",\n    \n    -- Authentication fields\n    authenticationProtocol = \"authentication.auth_protocol\",\n    authenticationRequirement = \"authentication.auth_requirement\"\n}\n\n-- Local helper functions for performance\nlocal function validate_ip(ip)\n    if not ip then return nil end\n    return string.match(ip, PATTERNS.ip) and ip or nil\nend\n\nlocal function validate_email(email)\n    if not email then return nil end\n    return string.match(email, PATTERNS.email) and email or nil\nend\n\nlocal function safe_copy(src, dest, field_name, target_field)\n    if src[field_name] then\n        dest[target_field] = src[field_name]\n        return true\n    end\n    return false\nend\n\nfunction transform(record)\n    -- Input validation\n    if not record or type(record) ~= \"table\" then\n        return nil, \"Invalid input record\"\n    end\n\n    -- Initialize output with required OCSF fields\n    local output = {\n        class_uid = 3002,\n        class_name = \"Authentication\", \n        category_uid = 3,\n        category_name = \"Identity & Access Management\",\n        activity_id = 1,\n        type_uid = 300201,\n        metadata = {},\n        time = record.time or os.time() * 1000,\n        \n        -- Initialize nested structures\n        user = {},\n        device = {},\n        src = {},\n        authentication = {},\n        access_activity = {}\n    }\n\n    -- Process core fields\n    for src_field, dest_field in pairs(FIELD_MAPPINGS) do\n        safe_copy(record, output, src_field, dest_field)\n    end\n\n    -- Special handling for critical fields\n    if record.userPrincipalName then\n        output.user.email_addr = validate_email(record.userPrincipalName)\n    end\n    \n    if record.callerIpAddress then\n        output.src.ip.address = validate_ip(record.callerIpAddress)\n    end\n\n    -- Process device details if present\n    if record.deviceDetail and type(record.deviceDetail) == \"table\" then\n        local device = record.deviceDetail\n        output.device = {\n            uid = device.deviceId,\n            os = device.operatingSystem,\n            browser = device.browser,\n            risk_detail = device.riskDetail,\n            risk_level = device.riskLevelAggregated,\n            risk_state = device.riskState\n        }\n    end\n\n    -- Process location if present\n    if record.location and type(record.location) == \"table\" then\n        output.location = {\n            city = record.location.city,\n            country = record.location.countryOrRegion,\n            region = record.location.state\n        }\n    end\n\n    -- Validation of required fields\n    if not output.time or not output.class_uid then\n        return nil, \"Missing required fields\"\n    end\n\n    return output\nend\n\n-- Error recovery wrapper\nfunction safe_transform(record)\n    local success, result = pcall(transform, record)\n    if not success then\n        return nil, string.format(\"Transform error: %s\", result)\n    end\n    return result\nend",
