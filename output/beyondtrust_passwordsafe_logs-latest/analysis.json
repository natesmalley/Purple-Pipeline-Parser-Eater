    "lua_code": "-- SentinelOne Parser: beyondtrust_passwordsafe_logs-latest \n-- OCSF Class: Access Activity (3005)\n-- Performance Level: High-volume optimized\n-- Generated: 2025-10-13T12:14:41.294444\n\n-- Pre-declare locals for performance\nlocal type = type\nlocal pairs = pairs\nlocal os_time = os.time\nlocal string_format = string.format\nlocal table_insert = table.insert\n\n-- Validation helper functions\nlocal function validate_string(value)\n    return type(value) == \"string\" and #value > 0\nend\n\nlocal function validate_number(value) \n    return type(value) == \"number\"\nend\n\n-- Main transform function\nfunction transform(record)\n    -- Input validation with early return\n    if not record or type(record) ~= \"table\" then\n        return nil, \"Invalid input record\"\n    end\n\n    -- Initialize output with required OCSF fields\n    local output = {\n        metadata = {\n            version = \"1.0.0\",\n            product = {\n                vendor_name = \"BeyondTrust\",\n                name = \"Password Safe\",\n                feature = {\n                    name = \"Access Activity Logging\"\n                }\n            }\n        },\n        class_uid = 3005,\n        class_name = \"Access Activity\", \n        category_uid = 3,\n        category_name = \"Identity & Access Management\",\n        time = os_time() * 1000,\n        access_activity = {},\n        user = {},\n        src = {\n            ip = {}\n        }\n    }\n\n    -- Safe nested table access helper\n    local function get_nested_value(t, ...)\n        local current = t\n        for _, k in ipairs({...}) do\n            if type(current) ~= \"table\" then return nil end\n            current = current[k]\n        end\n        return current\n    end\n\n    -- Extract nvps fields safely\n    local nvps = record.nvps or {}\n    \n    -- Map activity name\n    local event_name = nvps.eventname\n    if validate_string(event_name) then\n        output.access_activity.activity_name = event_name\n    end\n\n    -- Map username with validation\n    local username = nvps.username\n    if validate_string(username) then\n        output.user.name = username\n        -- Generate user ID if not present\n        if not output.user.uid then\n            output.user.uid = string_format(\"user_%s\", username:gsub(\"%s+\", \"_\"))\n        end\n    end\n\n    -- Map IP address with validation\n    local ip_addr = nvps.ipaddress\n    if validate_string(ip_addr) then\n        output.src.ip.address = ip_addr\n    end\n\n    -- Map additional fields with type checking\n    if validate_string(nvps.severity) then\n        output.access_activity.severity = nvps.severity\n    end\n\n    if validate_string(nvps.message) then\n        output.access_activity.message = nvps.message\n    end\n\n    -- Enrich with authentication context if available\n    if nvps.multifactorauthenticationenforced then\n        output.authentication = {\n            mfa = nvps.multifactorauthenticationenforced\n        }\n    end\n\n    -- Add session details if present\n    if validate_string(nvps.sessionmaskid) then\n        output.session = {\n            uid = nvps.sessionmaskid,\n            name = nvps.sessionmaskname\n        }\n    end\n\n    -- Validation before return\n    if not output.class_uid or output.class_uid == 0 then\n        return nil, \"Missing required OCSF class_uid\"\n    end\n\n    -- Add processing metadata\n    output.metadata.processed_time = os_time() * 1000\n    \n    return output\nend\n\n-- Error handler wrapper\nfunction safe_transform(record)\n    local success, result = pcall(transform, record)\n    if not success then\n        return nil, string_format(\"Transform error: %s\", result)\n    end\n    return result\nend",
