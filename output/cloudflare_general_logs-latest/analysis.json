    "lua_code": "-- SentinelOne Parser: cloudflare_general_logs-latest \n-- OCSF Class: Network Activity (4001)\n-- Performance Level: High-volume optimized\n-- Generated: 2025-10-13T12:23:58.149467\n\n-- Pre-compile patterns for performance\nlocal EMAIL_PATTERN = \"^[%w%.%-]+@[%w%.%-]+%.%w+$\"\nlocal TIMESTAMP_PATTERN = \"^%d+%.?%d*$\"\n\n-- Cached references for performance\nlocal type = type\nlocal tonumber = tonumber\nlocal os_time = os.time\nlocal string_match = string.match\nlocal string_format = string.format\n\n-- Helper functions\nlocal function validate_email(email)\n    if not email or type(email) ~= \"string\" then return false end\n    return string_match(email, EMAIL_PATTERN) ~= nil\nend\n\nlocal function parse_timestamp(ts)\n    if not ts then return nil end\n    if type(ts) == \"number\" then return ts end\n    if type(ts) == \"string\" and string_match(ts, TIMESTAMP_PATTERN) then\n        return tonumber(ts)\n    end\n    return nil\nend\n\nfunction transform(record)\n    -- Input validation with detailed error reporting\n    if not record then\n        return nil, \"Record is nil\"\n    end\n    if type(record) ~= \"table\" then\n        return nil, string_format(\"Invalid record type: %s\", type(record))\n    end\n\n    -- Initialize output with default values\n    local output = {\n        metadata = {\n            version = \"1.0.0\",\n            product = {\n                vendor_name = \"Cloudflare\",\n                name = \"Enterprise Logs\"\n            }\n        },\n        class_uid = 4001,\n        class_name = \"Network Activity\", \n        category_uid = 4,\n        category_name = \"Network Activity\",\n        activity_id = 99, -- Default activity\n        severity_id = 99, -- Default severity\n        status_id = 1,    -- Default status\n        time = parse_timestamp(record.CreatedAt) or os_time() * 1000,\n        actor = {\n            user = {}\n        },\n        src_endpoint = {},\n        dst_endpoint = {}\n    }\n\n    -- Optimized field mappings using local references\n    local actor = output.actor.user\n    local src = output.src_endpoint\n    local dst = output.dst_endpoint\n\n    -- Email handling with validation\n    if record.Email and validate_email(record.Email) then\n        actor.email_addr = record.Email\n        -- Extract username from email\n        actor.name = string_match(record.Email, \"([^@]+)@\") or record.Email\n    end\n\n    -- IP address handling\n    if record.IPAddress then\n        src.ip = record.IPAddress\n    end\n    if record.SourceIP then\n        src.ip = record.SourceIP\n    end\n    if record.DestinationIP then\n        dst.ip = record.DestinationIP\n    end\n\n    -- Port handling with type conversion\n    if record.SourcePort then\n        src.port = tonumber(record.SourcePort)\n    end\n    if record.DestinationPort then\n        dst.port = tonumber(record.DestinationPort)\n    end\n\n    -- Device information\n    if record.DeviceID then\n        src.uid = record.DeviceID\n    end\n    if record.DeviceName then\n        src.name = record.DeviceName\n    end\n\n    -- Validation before return\n    if not output.time then\n        return nil, \"Invalid timestamp\"\n    end\n\n    return output\nend\n\n-- Error handling wrapper for production use\nfunction safe_transform(record)\n    local success, result = pcall(transform, record)\n    if not success then\n        return nil, string_format(\"Transform error: %s\", result)\n    end\n    return result\nend",
