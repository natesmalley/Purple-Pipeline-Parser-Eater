# Purple Pipeline Parser Eater - Harness-First Environment Template
# Copy to `.env` and set real values before starting services.
#
# SECURITY:
# - Do not commit `.env` with real secrets.
# - Rotate API keys and tokens regularly.

# ============================================================================
# REQUIRED FOR HARNESS LLM GENERATION
# ============================================================================
# Provide at least ONE provider key. If both are set, OpenAI is preferred by default.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ============================================================================
# OPTIONAL FOR RAG PROFILE IN DOCKER COMPOSE
# ============================================================================
# Used only when running docker compose with `--profile rag`.
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ============================================================================
# OPTIONAL (HARNESS/WORKBENCH)
# ============================================================================
# Container image selection for docker-compose (registry-first).
# Defaults are set in docker-compose.yml; override here if needed.
# PPPE_IMAGE=ghcr.io/natesmalley/purple-pipeline-parser-eater
# PPPE_TAG=latest

# Optional integration keys (not required for core harness operation)
# GITHUB_TOKEN=ghp_your-github-token-here

# Optional LLM cost controls for workbench generation:
# Set provider preference explicitly to avoid accidental fallback behavior.
# If both keys are set, this controls which provider is used first.
LLM_PROVIDER_PREFERENCE=anthropic   # options: anthropic, openai
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-3-haiku-20240307
# Optional stronger fallback models used automatically when score is below threshold:
# OPENAI_STRONG_MODEL=gpt-5.2
# ANTHROPIC_STRONG_MODEL=claude-sonnet-4-5
# LLM_MAX_TOKENS=3000
