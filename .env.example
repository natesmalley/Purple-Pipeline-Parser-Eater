# Purple Pipeline Parser-Eater
# Environment Configuration Template
# Copy this file to .env and fill in your values
#
# SECURITY WARNING: Never commit the .env file to git
# SECURITY WARNING: Change all default passwords and tokens immediately
#

# ============================================================================
# REQUIRED: API KEYS & AUTHENTICATION
# ============================================================================

# Anthropic API Key (REQUIRED)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Web UI Authentication Token (REQUIRED)
WEB_UI_AUTH_TOKEN=your-secure-random-token-here

# ============================================================================
# OPTIONAL: EXTERNAL SERVICE INTEGRATIONS
# ============================================================================

# GitHub Integration
GITHUB_TOKEN=ghp_your-github-token-here
GITHUB_REPO=Purple-Pipeline-Parser-Eater

# Observo.ai Integration
OBSERVO_API_TOKEN=your-observo-api-token
OBSERVO_API_URL=https://api.observo.ai

# AWS S3 Integration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=purple-pipeline-events

# ============================================================================
# OPTIONAL: MILVUS VECTOR DATABASE
# ============================================================================

MILVUS_HOST=localhost
MILVUS_PORT=19530

# ============================================================================
# OPTIONAL: MINIO S3-COMPATIBLE STORAGE
# ============================================================================

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=purple-pipeline
MINIO_USE_SSL=false

# ============================================================================
# OPTIONAL: WEB UI CONFIGURATION
# ============================================================================

FLASK_SECRET_KEY=your-flask-secret-key-here
WEB_UI_HOST=127.0.0.1
WEB_UI_PORT=5000
WEB_UI_DEBUG=false

# TLS/HTTPS Configuration
WEB_UI_TLS_CERT=/path/to/cert.pem
WEB_UI_TLS_KEY=/path/to/key.pem

# ============================================================================
# OPTIONAL: RUNTIME SERVICE CONFIGURATION
# ============================================================================

LOG_LEVEL=INFO
MANIFEST_DIR=./output

# Message Bus Configuration
MESSAGE_BUS_TYPE=kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_INPUT_TOPIC=raw-security-events
KAFKA_OUTPUT_TOPIC=ocsf-events

# ============================================================================
# OPTIONAL: DATAPLANE EXECUTOR
# ============================================================================

DATAPLANE_BINARY_PATH=/opt/dataplane/dataplane
DATAPLANE_TIMEOUT_SECONDS=30

# ============================================================================
# OPTIONAL: DEVELOPMENT & TESTING
# ============================================================================

APP_ENV=development
TESTING_MODE=false
DRY_RUN_MODE=false

# ============================================================================
# OPTIONAL: LOGGING & MONITORING
# ============================================================================

LOGGING_OUTPUT=console
LOG_FILE_PATH=./logs/app.log
LOG_ROTATION_SIZE_MB=100
LOG_ROTATION_COUNT=10

# ============================================================================
# OPTIONAL: DATABASE CONFIGURATION
# ============================================================================

SQLITE_DB_PATH=./data/pipeline.db

# ============================================================================
# OPTIONAL: SECURITY SETTINGS
# ============================================================================

CORS_ORIGINS=http://localhost:3000,http://localhost:5000
RATE_LIMIT_REQUESTS_PER_MINUTE=60
SESSION_TIMEOUT_MINUTES=30

# ============================================================================
# OPTIONAL: PROXY & NETWORK
# ============================================================================

HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# ============================================================================
# OPTIONAL: PROMETHEUS METRICS
# ============================================================================

PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090
GITHUB_OWNER=natesmalley
