# Purple Pipeline Parser Eater - Harness-First Environment Template
# Copy to `.env` and set real values before starting services.
#
# SECURITY:
# - Do not commit `.env` with real secrets.
# - Rotate API keys and tokens regularly.

# ============================================================================
# REQUIRED FOR HARNESS LLM GENERATION
# ============================================================================
# Provide at least ONE provider key. Anthropic is preferred by default (see LLM_PROVIDER_PREFERENCE).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_STRONG_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_STRONG_MODEL=gpt-5.4

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_STRONG_MODEL=gemini-3.1-pro

LLM_PROVIDER_PREFERENCE=anthropic

# ============================================================================
# WEB UI AUTHENTICATION (plan Phase 1.D)
# ============================================================================
# Required whenever WEB_UI_HOST is NOT loopback (the docker-compose default
# binds 0.0.0.0, so this is required for `docker compose up`).
# Generate with: openssl rand -hex 32
# The service will refuse to start on a public interface without this set.
# Clients must send it as the `X-Auth-Token` header on every request.
WEB_UI_AUTH_TOKEN=

# ============================================================================
# OPTIONAL FOR RAG PROFILE IN DOCKER COMPOSE
# ============================================================================
# Used only when running docker compose with `--profile rag`.
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ============================================================================
# OPTIONAL (HARNESS/WORKBENCH)
# ============================================================================
# Container image selection for docker-compose (registry-first).
# Defaults are set in docker-compose.yml; override here if needed.
# PPPE_IMAGE=ghcr.io/natesmalley/purple-pipeline-parser-eater
# PPPE_TAG=latest

# Optional integration keys (not required for core harness operation)
# GITHUB_TOKEN=ghp_your-github-token-here

# LLM cost / behavior controls (optional):
# Provider preference is set above (LLM_PROVIDER_PREFERENCE=anthropic).
# Override there, not here, to avoid the duplicate-key bug from earlier
# upstream drafts that re-set the preference at the bottom of this file.
#
# OPENAI_API_MODE=auto           # options: auto, responses, chat_completions
# OPENAI_REASONING_EFFORT=low    # GPT-5 family only: none, low, medium, high, xhigh
# OPENAI_TEXT_VERBOSITY=medium   # GPT-5 family only: low, medium, high
# LLM_MAX_TOKENS=3000
# LLM_MAX_ITERATIONS=2
