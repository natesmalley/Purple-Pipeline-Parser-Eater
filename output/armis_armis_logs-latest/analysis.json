    "lua_code": "-- SentinelOne Parser: armis_armis_logs-latest \n-- OCSF Class: Security Finding (1001)\n-- Performance Level: High-volume optimized\n-- Generated: 2025-10-13T10:59:47.949551\n\n-- Pre-compile frequently used patterns\nlocal TIMESTAMP_PATTERN = \"^%d+%.?%d*$\"\n\n-- Cached references for better performance\nlocal type = type\nlocal pairs = pairs\nlocal tonumber = tonumber\nlocal os_time = os.time\nlocal string_format = string.format\n\n-- Validation helper functions\nlocal function validate_string(str)\n    return type(str) == \"string\" and str ~= \"\"\nend\n\nlocal function validate_number(num)\n    return type(num) == \"number\" and num > 0\nend\n\nfunction transform(record)\n    -- Input validation with early return\n    if not record or type(record) ~= \"table\" then\n        return nil, \"Invalid input record\"\n    end\n\n    -- Initialize OCSF-compliant output with required fields\n    local output = {\n        class_uid = 1001,\n        class_name = \"Security Finding\",\n        category_uid = 1, \n        category_name = \"Security Events\",\n        metadata = {\n            version = \"1.0.0\",\n            product = {\n                name = \"Armis\",\n                vendor = \"Armis\",\n                feature = {\n                    name = \"Security Platform\"\n                }\n            }\n        }\n    }\n\n    -- Optimized security finding mapping\n    if record.security_finding then\n        local finding = record.security_finding\n        output.finding = {\n            activity_id = finding.activity_id,\n            time = tonumber(finding.time) or os_time() * 1000,\n            severity = finding.severity,\n            message = finding.message,\n            type_name = finding.type_name,\n            data = finding.data\n        }\n    end\n\n    -- Efficient policy mapping with validation\n    if record.policy then\n        local policy = record.policy\n        output.policy_info = {\n            uid = policy.uid,\n            name = policy.name,\n            type = policy.type,\n            action = {\n                id = policy.action_id,\n                name = policy.action_name\n            },\n            effective_time = tonumber(policy.effective_time),\n            is_active = policy.is_active,\n            owner = policy.owner,\n            tags = policy.tags\n        }\n    end\n\n    -- Optimized device info mapping\n    if record.device then\n        local device = record.device\n        output.device_info = {\n            id = device.id,\n            name = device.name,\n            ip = device.ip,\n            ipv6 = device.ipv6,\n            category = device.category,\n            type = device.type,\n            model = device.model,\n            risk_level = device.risk_level,\n            location = device.location,\n            user = device.user,\n            metadata = {\n                is_corporate = device.is_corporate,\n                is_encrypted = device.is_encrypted,\n                is_sensor = device.is_sensor\n            }\n        }\n    end\n\n    -- Network connection mapping if present\n    if record.network_connection_info then\n        output.network = {\n            protocol = record.network_connection_info.protocol_name,\n            port = tonumber(record.network_endpoint.port)\n        }\n    end\n\n    -- Validation of critical fields\n    if not output.finding or not output.finding.time then\n        output.finding = output.finding or {}\n        output.finding.time = os_time() * 1000\n    end\n\n    -- Final validation before return\n    if not output.class_uid or output.class_uid == 0 then\n        return nil, \"Invalid OCSF class_uid\"\n    end\n\n    return output\nend\n\n-- Error handler wrapper\nfunction safe_transform(record)\n    local success, result = pcall(transform, record)\n    if not success then\n        return nil, string_format(\"Transform error: %s\", result)\n    end\n    return result\nend",
