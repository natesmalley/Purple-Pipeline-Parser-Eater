# Purple Pipeline Parser Eater - Harness-First Environment Template
# Copy to `.env` and set real values before starting services.
#
# SECURITY:
# - Do not commit `.env` with real secrets.
# - Rotate API keys and tokens regularly.

# ============================================================================
# REQUIRED FOR HARNESS LLM GENERATION
# ============================================================================
# Anthropic key used by default generation paths.
ANTHROPIC_API_KEY=sk-ant-your-key-here
# OpenAI key for dual-provider capability.
OPENAI_API_KEY=sk-your-openai-key-here

# ============================================================================
# REQUIRED FOR DOCKER COMPOSE STORAGE SERVICES
# ============================================================================
# Used by MinIO and Milvus integration in docker-compose.yml
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ============================================================================
# OPTIONAL (HARNESS/WORKBENCH)
# ============================================================================
# Workbench auth token. If omitted, compose defaults to local-dev-token.
# WEB_UI_AUTH_TOKEN=your-secure-random-token-here

# Optional integration keys (not required for core harness operation)
# GITHUB_TOKEN=ghp_your-github-token-here
# SDL_API_KEY=your-sdl-api-key
