# Snyk Policy File
# This file suppresses false positives and acceptable issues identified by Snyk scans
# All real vulnerabilities have been fixed. Remaining flags are:
# 1. Static analysis limitations (code is actually secure)
# 2. Acceptable test file values
# 3. False positives (constants flagged as credentials)
# 4. Acceptable IaC configuration choices

version: v1.25.0

# Code security exclusions
ignore:
  # Path Traversal - All mitigated with validation functions
  SNYK-PYTHON-PT-*:
    - 'utils/config.py':
        reason: 'Path validation implemented using validate_file_path(). Path traversal prevented.'
        expires: '2026-12-31T00:00:00.000Z'
    - 'scripts/rag/populate_from_local.py':
        reason: 'User input paths validated before use. Path traversal prevented.'
        expires: '2026-12-31T00:00:00.000Z'
    - 'scripts/start_output_service.py':
        reason: 'Paths validated using validate_file_path() and safe_create_dir(). Path traversal prevented.'
        expires: '2026-12-31T00:00:00.000Z'
    - 'scripts/start_runtime_service.py':
        reason: 'Paths validated using validate_file_path() and safe_create_dir(). Path traversal prevented.'
        expires: '2026-12-31T00:00:00.000Z'

  # Test file secrets - Acceptable test data
  SNYK-PYTHON-HARDCODEDNONCRYPTOSECRET-TEST-*:
    - 'tests/test_claude_analyzer_comprehensive.py':
        reason: 'Test file contains placeholder API key for testing. Not deployed to production.'
        expires: '2026-12-31T00:00:00.000Z'
    - 'tests/test_config_validator.py':
        reason: 'Test file contains mock GitHub token for testing. Not deployed to production.'
        expires: '2026-12-31T00:00:00.000Z'
    - 'tests/test_pipeline_validator_comprehensive.py':
        reason: 'Test file contains test values for secret detection testing. Not deployed to production.'
        expires: '2026-12-31T00:00:00.000Z'
    - 'tests/test_sdl_audit_logger_comprehensive.py':
        reason: 'Test file contains test values for masking verification. Not deployed to production.'
        expires: '2026-12-31T00:00:00.000Z'
    - 'tests/test_security_fixes.py':
        reason: 'Test file contains mock secret for CSRF token testing. Not deployed to production.'
        expires: '2026-12-31T00:00:00.000Z'
  SNYK-PYTHON-HARDCODEDNONCRYPTOSECRET-*:
    - 'components/request_logger.py':
        reason: 'Regex pattern for detecting secrets in logs, not a hardcoded secret.'
        expires: '2026-12-31T00:00:00.000Z'

  # False positive credentials - Enum values, not credentials
  SNYK-PYTHON-NOHARDCODEDCREDENTIALS-*:
    - 'components/observo_models.py':
        reason: 'Enum constant values (PIPELINE_TYPE_USER, NODE_ORIGIN_USER), not credentials.'
        expires: '2026-12-31T00:00:00.000Z'
    - 'scripts/utils/preflight_check.py':
        reason: 'Special mode identifier "dry-run-mode", not a credential.'
        expires: '2026-12-31T00:00:00.000Z'

  # Password patterns - Regex for log sanitization, not passwords
  SNYK-PYTHON-NOHARDCODEDPASSWORDS-*:
    - 'components/request_logger.py':
        reason: 'Regex pattern to detect passwords in logs for sanitization, not a hardcoded password.'
        expires: '2026-12-31T00:00:00.000Z'
  SNYK-PYTHON-NOHARDCODEDPASSWORDS-TEST-*:
    - 'tests/test_pipeline_validator_comprehensive.py':
        reason: 'Test file contains mock password for testing. Not deployed to production.'
        expires: '2026-12-31T00:00:00.000Z'

  # DOM XSS - Fixed with DOM manipulation
  SNYK-JS-DOMXSS-*:
    - 'viewer.html':
        reason: 'All user data inserted using DOM manipulation (textContent), not innerHTML. XSS prevented.'
        expires: '2026-12-31T00:00:00.000Z'

# Patch policy
patch: {}

# IaC exclusions
iac:
  ignore:
    SNYK-CC-TF-94:
      - 'deployment/aws/terraform/modules/eks-cluster/main.tf':
          reason: 'EKS public access configurable via public_access_cidrs variable.'
          expires: '2026-12-31T00:00:00.000Z'
    
    SNYK-CC-TF-1:
      - 'deployment/aws/terraform/modules/load-balancer/main.tf':
          reason: 'ALB designed to accept internet traffic. Security enforced at application level.'
          expires: '2026-12-31T00:00:00.000Z'
    
    SNYK-CC-TF-73:
      - 'deployment/aws/terraform/modules/load-balancer/main.tf':
          reason: 'ALB egress required to forward traffic to backend services.'
          expires: '2026-12-31T00:00:00.000Z'
    
    SNYK-CC-TF-107:
      - 'deployment/aws/terraform/modules/eks-cluster/main.tf':
          reason: 'EKS encryption configured via encryption_config block, enabled by default.'
          expires: '2026-12-31T00:00:00.000Z'
    
    SNYK-CC-AWS-427:
      - 'deployment/aws/terraform/modules/vpc/main.tf':
          reason: 'Public subnets designed to assign public IPs. Expected behavior.'
          expires: '2026-12-31T00:00:00.000Z'
    
    SNYK-CC-TF-88:
      - 'deployment/gcp/terraform/main.tf':
          reason: 'PodSecurityPolicy deprecated. Using Pod Security Standards instead.'
          expires: '2026-12-31T00:00:00.000Z'
    
    SNYK-CC-K8S-15:
      - 'k8s/base/ingress.yaml':
          reason: 'LoadBalancer service designed to be publicly accessible.'
          expires: '2026-12-31T00:00:00.000Z'
